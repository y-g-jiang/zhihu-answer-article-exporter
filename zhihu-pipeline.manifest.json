{
  "name": "zhihu-answer-article-exporter",
  "purpose": "Export a user's own Zhihu answers/articles into portable Markdown, rendered HTML, homepage preview pages, and a standalone static article collection.",
  "manual": "ZHIHU_EXPORT_PIPELINE.md",
  "agentInstructions": "AGENTS.md",
  "privacy": {
    "publishArticleContent": false,
    "publishGeneratedTargets": false,
    "privateOutputs": [
      "article-export-sample/",
      "content/",
      "docs/",
      "public/",
      "data/zhihu-targets.json",
      "data/slug-overrides.local.json"
    ],
    "privateState": [
      "browser-profile/",
      "**/browser-profile/",
      "profile-debug*.json",
      "profile-debug*.png"
    ]
  },
  "scripts": {
    "targets": "node scripts/build-zhihu-targets.mjs",
    "collectProfilePosts": "node scripts/collect-zhihu-profile-posts.mjs",
    "export": "node scripts/export-zhihu-sample.mjs",
    "buildLocalSite": "node scripts/build-zhihu-local-site.mjs",
    "buildPreview": "node scripts/build-zhihu-preview-pages.mjs",
    "buildStandaloneRepo": "node scripts/build-zhihu-article-repo.mjs",
    "publishGithub": "node scripts/publish-github.mjs"
  },
  "outputs": {
    "exportWorkspace": "article-export-sample",
    "homepagePreview": "public/zhihu",
    "standaloneRepo": "../zhihu-articles",
    "standalonePages": "../zhihu-articles/docs",
    "standaloneSource": "../zhihu-articles/content"
  },
  "cleanupPolicy": {
    "removeZhihuDirectEntityLinks": true,
    "unwrapLinkZhihuTargets": true,
    "removeLocalFileLinks": true,
    "preserveExportedLinkCards": true,
    "publishCompressedImagesOnlyInStandaloneRepo": true,
    "keepOriginalImagesOnlyInExportWorkspace": true
  },
  "mathPolicy": {
    "sourceSelector": ".ztext-math[data-tex]",
    "inlineSource": "data-eeimg=1",
    "displaySource": "data-eeimg=2",
    "htmlInlineDelimiter": "\\(...\\)",
    "htmlDisplayDelimiter": "\\[...\\]",
    "markdownInlineDelimiter": "$...$",
    "markdownDisplayDelimiter": "$$...$$",
    "renderer": "MathJax 3 tex-svg"
  }
}
